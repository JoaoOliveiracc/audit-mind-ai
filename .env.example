# === Provedor de LLM ===
# Provedor usado pelo agent. Suportados: anthropic, openai, azure_openai,
# google_genai, google_vertexai, groq, mistralai, cohere, together, fireworks,
# deepseek, bedrock, ollama. Cada provedor exige seu pacote (ver README) e sua credencial.
AUDITOR_PROVIDER=google_genai

# === Credenciais (defina a do provedor escolhido) ===
# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OpenAI
# OPENAI_API_KEY=sk-...
# Google (Gemini)
# GOOGLE_API_KEY=...
# Groq
# GROQ_API_KEY=...
# Mistral
# MISTRAL_API_KEY=...
# DeepSeek
# DEEPSEEK_API_KEY=sk-...
# Ollama e Bedrock não usam chave (local / credenciais AWS).

# === Modelo ===
# Modelo usado pelo agent. Ex.:
#   anthropic     -> claude-sonnet-4-5, claude-opus-4-8
#   openai        -> gpt-4o, o4-mini
#   google_genai  -> gemini-2.0-flash
#   groq          -> llama-3.3-70b-versatile
#   deepseek      -> deepseek-chat, deepseek-reasoner
#   ollama        -> qwen2.5-coder:14b, llama3.1
AUDITOR_MODEL=gemini-2.0-flash
# Endpoint customizado (Ollama, gateway compatível com OpenAI, etc.). Ex.:
#   http://localhost:11434  (Ollama)
# AUDITOR_BASE_URL=
# Temperatura (0 = determinístico, recomendado para auditoria)
AUDITOR_TEMPERATURE=0
# Máximo de tokens de saída por chamada
AUDITOR_MAX_TOKENS=8000

# === Limites de varredura ===
# Tamanho máximo (em bytes) de arquivo lido individualmente
AUDITOR_MAX_FILE_BYTES=200000
# Máximo de arquivos considerados no inventário
AUDITOR_MAX_FILES=5000
# Máximo de resultados por busca de código
AUDITOR_MAX_SEARCH_RESULTS=50
# Passos máximos de raciocínio por investigador ReAct
AUDITOR_MAX_INVESTIGATOR_STEPS=80

# === Comportamento ===
# Nível de log: DEBUG, INFO, WARNING, ERROR
AUDITOR_LOG_LEVEL=INFO
# Diretório de saída dos relatórios
AUDITOR_OUTPUT_DIR=./audit-reports
# Verificação determinística de evidência (descarta achados não-substanciados)
AUDITOR_VERIFY_EVIDENCE=true
